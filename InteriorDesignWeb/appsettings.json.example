{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "InteriorDesignWeb.Services.Assistant": "Information",
      "InteriorDesignWeb.Middlewares.RequestTelemetryMiddleware": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DesignDB": "Server=localhost;Port=3306;Database=aisj_club;Uid=root;Pwd=your_password_here;"
  },
  "JwtSettings": {
    "Secret": "your-jwt-secret-key-here",
    "Issuer": "designhub-server",
    "Audience": "designhub-client",
    "ExpireMinutes": 3000
  },
  "Blinky": {
    "Endpoint": "https://blinky.nemui.org/shot",
    "DefaultWidth": 320,
    "AllowedHosts": [ "https://localhost:7207/" ]
  },
  "RoleLimits": {
    "SchemeCreation": {
      "FreeUser": 3,
      "Member": 10,
      "PremiumMember": 999
    },
    "ImagesPerScheme": {
      "FreeUser": 20,
      "Member": 100,
      "PremiumMember": 9999
    }
  },
  "COS": {
    "SecretId": "your-cos-secret-id",
    "SecretKey": "your-cos-secret-key",
    "Region": "ap-guangzhou",
    "Bucket": "your-bucket-name",
    "AppId": "your-app-id",
    "BaseUrl": "https://your-bucket.cos.ap-guangzhou.myqcloud.com",
    "ThumbnailSuffix": "_thumbnail",
    "AIBucket": "your-ai-bucket",
    "AIRegion": "ap-guangzhou",
    "AIBaseUrl": "https://your-ai-bucket.cos.ap-guangzhou.myqcloud.com"
  },
  "ComfyUI": {
    "ApiUrl": "http://192.168.1.20:8188/",
    "AccountApiKey": "",
    "AuthorizationHeader": "",
    "ClientId": "interior-design-web",
    "RequestTimeoutMinutes": 15,
    "PollIntervalSeconds": 3,
    "MaxPollAttempts": 600,
    "MaxUploadBytes": 52428800,
    "UseProxy": false,
    "AllowInvalidCertificate": false
  },
  "AgentPlatform": {
    "Enabled": false,
    "ConfigurationRoot": "AIAgent",
    "StrictValidation": true,
    "FallbackToLegacy": true,
      "MaxModelCallsPerRun": 5
  },
  "AgentModels": {
    "Profiles": {
      "minimax_frontdesk": {
        "Enabled": true,
        "Provider": "minimax",
        "Protocol": "anthropic",
        "BaseUrl": "https://api.minimaxi.com/anthropic/",
        "ApiKey": "your-minimax-api-key",
        "Model": "MiniMax-M3",
        "TimeoutSeconds": 120,
        "MaxOutputTokens": 4000,
        "ThinkingMode": "disabled",
        "Capabilities": { "Text": true, "Vision": false, "Tools": true, "JsonOutput": false, "Thinking": true }
      },
      "deepseek_worker": {
        "Enabled": true,
        "Provider": "deepseek",
        "Protocol": "openai",
        "BaseUrl": "https://api.deepseek.com/",
        "ApiKey": "your-deepseek-api-key",
        "Model": "deepseek-v4-flash",
        "TimeoutSeconds": 180,
        "MaxOutputTokens": 8000,
        "ThinkingMode": "enabled",
        "ReasoningEffort": "high",
        "Capabilities": { "Text": true, "Vision": false, "Tools": true, "JsonOutput": true, "Thinking": true }
      },
      "deepseek_design_pro": {
        "Enabled": true,
        "Provider": "deepseek",
        "Protocol": "openai",
        "BaseUrl": "https://api.deepseek.com/",
        "ApiKey": "your-deepseek-api-key",
        "Model": "deepseek-v4-pro",
        "TimeoutSeconds": 300,
        "MaxOutputTokens": 16000,
        "ThinkingMode": "enabled",
        "ReasoningEffort": "high",
        "Capabilities": { "Text": true, "Vision": false, "Tools": true, "JsonOutput": true, "Thinking": true }
      },
      "volc_vision": {
        "Enabled": true,
        "Provider": "volc-ark",
        "Protocol": "responses",
        "BaseUrl": "https://ark.cn-beijing.volces.com/api/v3/",
        "ApiKey": "your-volc-ark-api-key",
        "Model": "doubao-seed-2-1-turbo-260628",
        "TimeoutSeconds": 180,
        "MaxOutputTokens": 8000,
        "ThinkingMode": "disabled",
        "Capabilities": { "Text": true, "Vision": true, "Tools": true, "JsonOutput": true, "Thinking": true }
      }
    }
  }
}
